{
    "name": "php/web-php",
    "description": "The www.php.net site.",
    "license": "proprietary",
    "type": "project",
    "homepage": "https://www.php.net/",
    "support": {
        "source": "https://github.com/php/web-php"
    },
    "require": {
        "php": "~8.4.0"
    },
    "require-dev": {
        "ext-curl": "*",
        "friendsofphp/php-cs-fixer": "^3.95.10",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "phpweb\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "phpweb\\Test\\": "tests/"
        }
    },
    "config": {
        "platform": {
            "php": "8.4.0"
        },
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
